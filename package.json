{
  "name": "survhub",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @survhub/server",
    "dev:web": "npm run dev -w @survhub/web",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w @survhub/server"
  }
}
