{
  "name": "survhub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @survhub/server",
    "dev:web": "npm run dev -w @survhub/web",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w @survhub/server",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "lint:fix": "eslint apps packages --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.11.0"
  }
}
